{
    "elliott_wave_knowledge_base": {
        "canonical_patterns": {
            "zigzag_family": [
                {
                    "id": "zigzag",
                    "name": "Zigzag",
                    "structure": "5-3-5",
                    "components": {
                        "A": 5,
                        "B": 3,
                        "C": 5
                    },
                    "behavior": [
                        "sharp_correction",
                        "directional",
                        "counter_trend"
                    ],
                    "rules": [
                        "B_usually_retraces_38_to_61_percent_of_A",
                        "B_rarely_exceeds_A_start",
                        "C_usually_equals_A_or_1_618x_A"
                    ]
                },
                {
                    "id": "double_zigzag",
                    "name": "Double Zigzag",
                    "structure": "W-X-Y",
                    "internal_structure": "(5-3-5)-(3)-(5-3-5)",
                    "behavior": [
                        "deep_correction",
                        "directional"
                    ],
                    "rules": [
                        "X_is_corrective_3_wave",
                        "Y_is_another_zigzag"
                    ]
                },
                {
                    "id": "triple_zigzag",
                    "name": "Triple Zigzag",
                    "structure": "W-X-Y-X-Z",
                    "internal_structure": "(5-3-5)-(3)-(5-3-5)-(3)-(5-3-5)",
                    "behavior": [
                        "very_deep_correction",
                        "rare"
                    ]
                }
            ],
